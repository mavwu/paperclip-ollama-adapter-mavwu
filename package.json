{
  "name": "paperclip-ollama-adapter-mavwu",
  "version": "1.0.4",
  "description": "Paperclip external adapter for Ollama and local LLMs",
  "type": "module",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": "./dist/index.js",
    "./manifest": "./dist/manifest.js",
    "./server": "./dist/server/index.js"
  },
  "paperclipPlugin": {
    "manifest": "./dist/manifest.js"
  },
  "files": [
    "dist",
    "README.md",
    "CONFIGURATION.md"
  ],
  "scripts": {
