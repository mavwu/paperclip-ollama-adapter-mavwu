    "test": "npm run build && node dist/server/test.js",
    "prepublishOnly": "npm run build"
  },
  "keywords": [
    "paperclip",
    "paperclipai",
    "adapter",
    "ollama",
    "llm",
    "ai"
  ],
  "author": "Alfred Mavwu",
  "license": "MIT",
  "dependencies": {
    "@paperclipai/adapter-utils": "^2026.609.0",
    "axios": "^1.18.0",
    "dotenv": "^16.6.1"
  },
  "devDependencies": {
    "@types/node": "^24.6.0",
    "typescript": "^6.0.3"
  },
  "engines": {
    "node": ">=18.0.0"
  }
}
